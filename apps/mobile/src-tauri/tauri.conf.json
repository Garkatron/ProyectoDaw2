{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Limpora",
  "version": "0.1.0",
  "identifier": "com.limpora.mobile",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://www.limpora.xyz",
    "beforeBuildCommand": "",
    "frontendDist": "https://www.limpora.xyz"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Limpora",
        "url": "https://www.limpora.xyz",
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  }
}