# ---------- BUILD ----------
FROM node:20-alpine AS build

WORKDIR /app

# Copiar manifests
COPY package*.json ./

# Instalar dependencias (NO npm ci)
RUN npm install

# Copiar código
COPY . .

# Build
RUN npm run build


# ---------- RUNTIME ----------
FROM node:20-alpine

WORKDIR /app

# Instalar serve global
RUN npm install -g serve

# Copiar build
COPY --from=build /app/dist ./dist

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
